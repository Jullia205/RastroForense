<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controller.telascontrol.TelaAcusacaoController"
        prefWidth="960"
        prefHeight="540"
        style="-fx-background-color: #0D0D0D;">

    <top>
        <VBox style="-fx-background-color: #0D0D0D;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 20 12 20;">
                <Label
                        text="VOLTAR"
                        onMouseClicked="#handleVoltar"
                        style="
                        -fx-font-family: 'Courier New';
                        -fx-font-size: 11px;
                        -fx-text-fill: #AAAAAA;
                        -fx-font-weight: BOLD;
                        -fx-cursor: hand;
                    "/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label
                        fx:id="lblTituloCaso"
                        text="CASO - 0000000"
                        style="
                        -fx-font-family: 'Impact';
                        -fx-font-size: 32px;
                        -fx-text-fill: #8B1010;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 4, 0, 1, 1);
                    "/>
            </HBox>
            <Separator style="-fx-background-color: #3A3A3A;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane
                fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                pannable="true">
            <content>
                <FlowPane
                        fx:id="painelSuspeitos"
                        hgap="24"
                        vgap="24"
                        alignment="CENTER"
                        style="-fx-padding: 40; -fx-background-color: #0D0D0D;">
                </FlowPane>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 16 30 16 30; -fx-background-color: #0D0D0D;">
            <Button
                    fx:id="btnAcusar"
                    text="ACUSAR"
                    onAction="#handleAcusar"
                    style="
                    -fx-font-family: 'Courier New';
                    -fx-font-size: 14px;
                    -fx-font-weight: BOLD;
                    -fx-text-fill: #FFFFFF;
                    -fx-background-color: #CC2222;
                    -fx-background-radius: 20px;
                    -fx-padding: 10 24 10 24;
                    -fx-cursor: hand;
                "/>
        </HBox>
    </bottom>

</BorderPane>