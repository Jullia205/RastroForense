<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controller.telascontrol.TelaFinalController"
        prefWidth="960"
        prefHeight="540"
        style="-fx-background-color: #0D0D0D;">

    <top>
        <VBox style="-fx-background-color: #0D0D0D;">
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 12 20 12 20;">
                <Label
                        fx:id="lblTituloCaso"
                        text="CASO - 0000000"
                        style="
                        -fx-font-family: 'Impact';
                        -fx-font-size: 32px;
                        -fx-text-fill: #8B1010;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 4, 0, 1, 1);
                    "/>
            </HBox>
            <Separator style="-fx-background-color: #3A3A3A;"/>
        </VBox>
    </top>

    <center>
        <HBox alignment="CENTER" style="-fx-padding: 40; -fx-background-color: #0D0D0D;">

            <!-- Painel esquerdo: detalhes do caso -->
            <VBox
                    alignment="TOP_LEFT"
                    spacing="16"
                    style="
                    -fx-background-color: #1A1515;
                    -fx-padding: 24;
                    -fx-background-radius: 4;
                "
                    prefWidth="300"
                    prefHeight="360">
                <Label
                        fx:id="lblDetalhesFinais"
                        wrapText="true"
                        maxWidth="260"
                        style="
                        -fx-font-family: 'Courier New';
                        -fx-font-size: 11px;
                        -fx-text-fill: #888888;
                    "/>
            </VBox>

            <!-- Painel direito: texto do final -->
            <VBox
                    alignment="TOP_LEFT"
                    spacing="0"
                    style="
                    -fx-background-color: #2A1515;
                    -fx-background-radius: 4;
                "
                    prefWidth="540"
                    prefHeight="360">
                <Label
                        fx:id="lblTextoFinal"
                        wrapText="true"
                        maxWidth="500"
                        style="
                        -fx-font-family: 'Courier New';
                        -fx-font-size: 12px;
                        -fx-text-fill: #C8B8B8;
                        -fx-padding: 24;
                    "/>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 16 30 16 30; -fx-background-color: #0D0D0D;">
            <Button
                    fx:id="btnEncerrar"
                    text="▶"
                    onAction="#handleEncerrar"
                    style="
                    -fx-background-color: transparent;
                    -fx-text-fill: #CC8888;
                    -fx-font-size: 22px;
                    -fx-cursor: hand;
                "/>
        </HBox>
    </bottom>

</BorderPane>