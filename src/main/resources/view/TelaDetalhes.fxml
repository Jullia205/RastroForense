<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controller.telascontrol.TelaDetalhesController"
        prefWidth="960"
        prefHeight="540"
        style="-fx-background-color: #0D0D0D;">

    <!-- Imagem de fundo (escada escura) -->
    <!-- Substitua o caminho pelo arquivo real no seu projeto -->
    <ImageView
            fx:id="imgFundo"
            fitWidth="960"
            fitHeight="540"
            preserveRatio="false"
            pickOnBounds="true">
        <image>
            <Image url="@../images/fundodetalhes.png"/>
        </image>
    </ImageView>

    <!-- Painel do caso — alinhado à direita -->
    <HBox alignment="CENTER_RIGHT" pickOnBounds="false">
        <padding>
            <Insets right="50"/>
        </padding>

        <!-- Card escuro do protocolo -->
        <VBox
                fx:id="painelCaso"
                alignment="TOP_CENTER"
                spacing="16"
                style="
                -fx-background-color: rgba(30,25,25,0.92);
                -fx-border-color: #3A3A3A;
                -fx-border-width: 1px;
                -fx-padding: 36 40 32 40;
            "
                prefWidth="310"
                prefHeight="400">


            <!-- Título do caso -->
            <Label
                    fx:id="lblProtocolo"
                    text="CASO"
                    wrapText="true"
                    maxWidth="230"
                    alignment="CENTER"
                    style="
                    -fx-font-family: 'Courier New';
                    -fx-font-size: 20px;
                    -fx-font-weight: BOLD;
                    -fx-text-fill: #C8B0B0;
                    -fx-text-alignment: CENTER;
            "/>

            <!-- Detalhes do caso -->
            <Label
                    fx:id="txtDetalhesCaso"
                    wrapText="true"
                    maxWidth="230"
                    style="
                    -fx-font-family: 'Courier New';
                    -fx-font-size: 14px;
                    -fx-text-fill: #C8B8B8;
            "/>

            <!-- Espaço flexível empurra botão para baixo -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Botão ANALISAR -->
            <Button
                    fx:id="btnAnalisar"
                    text="ANALISAR"
                    onAction="#handleAnalisar"
                    style="
                    -fx-font-family: 'Courier New';
                    -fx-font-size: 13px;
                    -fx-font-weight: BOLD;
                    -fx-text-fill: #5A3A3A;
                    -fx-background-color: #E8C8C8;
                    -fx-border-color: #C8A0A0;
                    -fx-border-width: 1px;
                    -fx-padding: 10 40 10 40;
                    -fx-cursor: hand;
                    -fx-background-radius: 2px;
                "
                    maxWidth="Infinity"
                    onMouseEntered="#handleBtnHoverEnter"
                    onMouseExited="#handleBtnHoverExit"
            />

        </VBox>
    </HBox>

</StackPane>
